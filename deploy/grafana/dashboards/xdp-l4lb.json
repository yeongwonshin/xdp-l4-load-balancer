{
  "title": "XDP L4 Load Balancer",
  "uid": "xdp-l4lb",
  "tags": ["xdp", "ebpf", "load-balancer"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Backend packets per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(xdp_l4lb_backend_packets_total[1m])",
          "legendFormat": "{{service}} / {{backend}}",
          "refId": "a"
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Backend bytes per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(xdp_l4lb_backend_bytes_total[1m])",
          "legendFormat": "{{service}} / {{backend}}",
          "refId": "a"
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "New flows per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(xdp_l4lb_backend_flows_total[1m])",
          "legendFormat": "{{service}} / {{backend}}",
          "refId": "a"
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "Datapath events per second",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (event) (rate(xdp_l4lb_datapath_events_total[1m]))",
          "legendFormat": "{{event}}",
          "refId": "a"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    }
  ]
}
